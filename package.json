{
  "name": "hnefatafl-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "postinstall": "wrangler types",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply hnefatafl-db --local",
    "db:apply": "wrangler d1 migrations apply hnefatafl-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.0",
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.90.0"
  }
}
